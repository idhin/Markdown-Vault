<% var pageTitle = 'Admin - ' + project.name; %>
<%- include('../partials/head') %>
<%- include('../partials/nav', { isAdmin: true }) %>
<main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
  <div class="mb-6">
    <a href="/admin" class="text-sm text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">&larr; Semua Projects</a>
  </div>

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-3xl font-bold"><%= project.name %></h1>
      <div class="mt-2 flex items-center gap-3">
        <span class="text-sm text-gray-500 dark:text-gray-400">Share URL:</span>
        <code class="text-sm bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-lg font-mono text-blue-600 dark:text-blue-400 select-all">/s/<%= project.uuid %></code>
        <button onclick="copyLink('/s/<%= project.uuid %>')" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Copy</button>
      </div>
    </div>
    <div class="flex gap-2">
      <a href="/admin/project/<%= project.id %>/page/new"
        class="inline-flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Halaman Baru
      </a>
      <button onclick="document.getElementById('upload-modal').classList.remove('hidden')"
        class="inline-flex items-center gap-2 px-4 py-2.5 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 font-medium transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
        Upload .md
      </button>
      <button onclick="document.getElementById('project-settings').classList.toggle('hidden')"
        class="p-2.5 border border-gray-300 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" title="Settings">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </button>
    </div>
  </div>

  <!-- Project Settings (hidden) -->
  <div id="project-settings" class="hidden mb-6 bg-white dark:bg-gray-900 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-800 p-6">
    <h3 class="font-semibold mb-4">Project Settings</h3>
    <form method="POST" action="/admin/project/<%= project.id %>/update" class="flex gap-3 mb-4">
      <input type="text" name="name" value="<%= project.name %>" required
        class="flex-1 px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none">
      <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition-colors">Simpan</button>
    </form>
    <form method="POST" action="/admin/project/<%= project.id %>/delete" onsubmit="return confirm('Hapus project ini dan semua halamannya?')">
      <button type="submit" class="text-sm text-red-600 dark:text-red-400 hover:underline">Hapus Project</button>
    </form>
  </div>

  <% if (pages.length === 0) { %>
    <div class="text-center py-20">
      <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      <p class="mt-4 text-gray-500 dark:text-gray-400">Belum ada halaman. Buat halaman pertamamu!</p>
    </div>
  <% } else { %>
    <div class="space-y-3">
      <% pages.forEach(function(pg) { %>
        <% var expired = pg.expiresAt && new Date(pg.expiresAt) < new Date(); %>
        <div class="bg-white dark:bg-gray-900 rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 p-5 flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <h3 class="font-semibold truncate"><%= pg.title %></h3>
              <% if (expired) { %>
                <span class="shrink-0 text-xs px-2 py-0.5 bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-full">Expired</span>
              <% } %>
            </div>
            <div class="mt-1 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 dark:text-gray-400">
              <span>/<%= pg.slug %></span>
              <span><%= pg.viewCount || 0 %> views</span>
              <% if (pg.expiresAt) { %>
                <span>Expires: <%= new Date(pg.expiresAt).toLocaleDateString('id-ID') %></span>
              <% } %>
            </div>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button onclick="copyLink('/s/<%= project.uuid %>/<%= pg.slug %>')"
              class="p-2 text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" title="Copy share link">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
            </button>
            <a href="/admin/project/<%= project.id %>/page/<%= pg.id %>/edit"
              class="p-2 text-gray-500 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" title="Edit">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </a>
            <form method="POST" action="/admin/project/<%= project.id %>/page/<%= pg.id %>/delete" onsubmit="return confirm('Hapus halaman ini?')" class="inline">
              <button type="submit" class="p-2 text-gray-500 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors" title="Hapus">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
  <!-- Upload .md Modal -->
  <div id="upload-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-xl border border-gray-200 dark:border-gray-800 p-8 w-full max-w-lg mx-4">
      <h2 class="text-xl font-bold mb-2">Upload File Markdown</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Upload file .md beserta gambar/asset yang direferensikan di dalamnya. Struktur folder akan dipertahankan.</p>
      <form method="POST" action="/admin/project/<%= project.id %>/upload" enctype="multipart/form-data">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">File .md + Gambar/Assets</label>
          <div id="upload-dropzone" class="border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-xl p-8 text-center hover:border-blue-400 dark:hover:border-blue-500 transition-colors cursor-pointer">
            <svg class="w-10 h-10 mx-auto text-gray-400 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
            <p class="text-sm text-gray-600 dark:text-gray-400">Drag & drop files atau <span class="text-blue-600 dark:text-blue-400 font-medium">browse</span></p>
            <p class="text-xs text-gray-400 mt-1">Pilih file .md dan semua gambar/folder yang direferensikan</p>
            <input type="file" name="files" multiple webkitdirectory class="hidden" id="upload-files-dir">
            <input type="file" name="files" multiple class="hidden" id="upload-files-flat">
          </div>
          <div class="mt-2 flex gap-2">
            <button type="button" onclick="document.getElementById('upload-files-flat').click()"
              class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Pilih Files</button>
            <span class="text-gray-300 dark:text-gray-600">|</span>
            <button type="button" onclick="document.getElementById('upload-files-dir').click()"
              class="text-sm text-blue-600 dark:text-blue-400 hover:underline">Pilih Folder</button>
          </div>
          <div id="upload-file-list" class="mt-3 text-sm text-gray-600 dark:text-gray-400 max-h-40 overflow-y-auto"></div>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Password untuk halaman</label>
          <input type="text" name="password" required placeholder="Password akses halaman"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Expiry Date <span class="text-gray-400 font-normal">(opsional)</span></label>
          <input type="datetime-local" name="expiresAt"
            class="w-full sm:w-auto px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>
        <div class="flex gap-3">
          <button type="button" onclick="document.getElementById('upload-modal').classList.add('hidden')"
            class="flex-1 py-2.5 px-4 border border-gray-300 dark:border-gray-700 rounded-lg font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Batal</button>
          <button type="submit" id="upload-submit-btn"
            class="flex-1 py-2.5 px-4 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors">Upload & Buat Halaman</button>
        </div>
      </form>
    </div>
  </div>
</main>
<script>
(function() {
  const fileInputFlat = document.getElementById('upload-files-flat');
  const fileInputDir = document.getElementById('upload-files-dir');
  const fileList = document.getElementById('upload-file-list');
  const dropzone = document.getElementById('upload-dropzone');
  const form = dropzone.closest('form');

  let collectedFiles = new DataTransfer();

  function addFiles(newFiles) {
    for (const f of newFiles) {
      collectedFiles.items.add(f);
    }
    renderFileList();
  }

  function renderFileList() {
    const files = collectedFiles.files;
    if (files.length === 0) {
      fileList.innerHTML = '';
      return;
    }
    const mdCount = Array.from(files).filter(f => f.name.endsWith('.md')).length;
    const imgCount = files.length - mdCount;
    fileList.innerHTML = '<span class="font-medium">' + files.length + ' file dipilih</span> (' + mdCount + ' .md, ' + imgCount + ' assets)';

    fileInputFlat.files = collectedFiles.files;
  }

  fileInputFlat.addEventListener('change', () => { addFiles(fileInputFlat.files); });
  fileInputDir.addEventListener('change', () => { addFiles(fileInputDir.files); });

  dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-blue-400', 'dark:border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/10'); });
  dropzone.addEventListener('dragleave', () => { dropzone.classList.remove('border-blue-400', 'dark:border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/10'); });
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-blue-400', 'dark:border-blue-500', 'bg-blue-50', 'dark:bg-blue-900/10');
    addFiles(e.dataTransfer.files);
  });
})();

function copyLink(path) {
  const url = window.location.origin + path;
  navigator.clipboard.writeText(url).then(() => {
    const toast = document.createElement('div');
    toast.textContent = 'Link disalin!';
    toast.className = 'fixed bottom-6 right-6 bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-4 py-2 rounded-lg shadow-lg text-sm font-medium z-50 animate-fade-in';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2000);
  });
}
</script>
<%- include('../partials/footer') %>
